{
  "manifest_version": 3,
  "name": "Coremi Team Community Lite",
  "version": "1.0.2",
  "description": "Local-first AI team workspace for multi-model discussion",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "tabs",
    "declarativeNetRequest",
    "clipboardRead",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://gemini.google.com/*",
    "https://*.gemini.google.com/*",
    "https://chatgpt.com/*",
    "https://*.chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://chat.deepseek.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; frame-src https://gemini.google.com https://*.gemini.google.com https://chatgpt.com https://*.chatgpt.com https://chat.openai.com https://claude.ai https://chat.deepseek.com;"
  },
  "action": {
    "default_title": "Coremi Team Community Lite",
    "default_icon": {
      "16": "icons/coremi-team-16.png",
      "32": "icons/coremi-team-32.png",
      "48": "icons/coremi-team-48.png",
      "128": "icons/coremi-team-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://gemini.google.com/*",
        "*://*.gemini.google.com/*",
        "*://chatgpt.com/*",
        "*://*.chatgpt.com/*",
        "*://chat.openai.com/*",
        "*://claude.ai/*",
        "*://chat.deepseek.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ai_iframe_rules",
        "enabled": true,
        "path": "openteam-frame-rules.json"
      }
    ]
  },
  "icons": {
    "16": "icons/coremi-team-16.png",
    "32": "icons/coremi-team-32.png",
    "48": "icons/coremi-team-48.png",
    "128": "icons/coremi-team-128.png"
  }
}
